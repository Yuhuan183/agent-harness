#!/usr/bin/env python3
"""Append-only, machine-local skill observation ledger."""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import re
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, TextIO


SCHEMA_VERSION = 1
DEFAULT_LEDGER = Path.home() / ".agents" / "telemetry" / "skill-observations.jsonl"
VALID_TYPES = ("open-source", "internal")
VALID_RESOLUTIONS = ("actioned", "declined")
SKILL_NAME = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
SOURCE_MARKER = ".agent-harness-source"
CREATED_TEXT_FIELDS = (
    "skill",
    "area",
    "issue",
    "suggested_improvement",
    "principle",
)


class LedgerError(ValueError):
    """The ledger or requested transition is invalid."""


def now() -> str:
    return datetime.now(timezone.utc).isoformat()


def ledger_path() -> Path:
    override = os.environ.get("AGENT_SKILL_OBSERVATIONS")
    return Path(override).expanduser() if override else DEFAULT_LEDGER


def skill_root(override: str | None = None) -> Path:
    configured = override or os.environ.get("AGENT_SKILLS_ROOT")
    return (
        Path(configured).expanduser()
        if configured
        else Path.home() / ".agents" / "skills"
    )


def read_skill_inventory(root: Path, *, required: bool = False) -> set[str]:
    inventory = root / "INSTALLED.txt"
    if not inventory.exists():
        if required:
            raise LedgerError(f"project skill inventory does not exist: {inventory}")
        return set()
    names = inventory.read_text(encoding="utf-8").splitlines()
    if not names or any(not SKILL_NAME.fullmatch(name) for name in names):
        raise LedgerError(f"invalid project skill inventory: {inventory}")
    if len(names) != len(set(names)):
        raise LedgerError(f"duplicate project skill in inventory: {inventory}")
    return set(names)


def source_in_checkout(checkout: Path, skill: str) -> Path | None:
    checkout = checkout.expanduser().resolve()
    if not (checkout / ".git").exists():
        return None
    source_root = checkout / "main" / ".agents" / "skills"
    try:
        names = read_skill_inventory(source_root, required=True)
    except (LedgerError, OSError):
        return None
    manifest = checkout / "scripts" / "deployment-manifest.tsv"
    try:
        rows = {
            tuple(line.split("\t"))
            for line in manifest.read_text(encoding="utf-8").splitlines()
            if line and not line.startswith("#")
        }
    except OSError:
        return None
    source = source_root / skill
    if (
        skill in names
        and ("main/.agents/skills", ".agents/skills", "merge") in rows
        and (source / "SKILL.md").is_file()
    ):
        return source
    return None


def candidate_checkouts(
    deployed_root: Path, explicit: str | None
) -> tuple[list[Path], bool]:
    if explicit:
        return [Path(explicit)], True
    configured = os.environ.get("AGENT_HARNESS_CHECKOUT")
    if configured:
        return [Path(configured)], True

    # A script invoked from a source checkout is stronger evidence than the
    # marker from the last deployment, which may still name an older checkout.
    script_start = Path(__file__).resolve().parent
    candidates = [script_start, *script_start.parents]
    marker = deployed_root / SOURCE_MARKER
    if marker.exists():
        lines = marker.read_text(encoding="utf-8").splitlines()
        if len(lines) != 1 or not lines[0].strip():
            raise LedgerError(f"invalid source checkout marker: {marker}")
        candidates.append(Path(lines[0]))
    cwd = Path.cwd().resolve()
    candidates.extend((cwd, *cwd.parents))
    return candidates, False


def command_target(args: argparse.Namespace) -> int:
    if not SKILL_NAME.fullmatch(args.skill):
        raise LedgerError("skill must use lowercase hyphen-case")
    deployed_root = skill_root(args.skill_root)
    deployed = deployed_root / args.skill
    installed_names = read_skill_inventory(deployed_root)
    candidates, authoritative = candidate_checkouts(deployed_root, args.checkout)

    source = None
    seen: set[Path] = set()
    for candidate in candidates:
        resolved = candidate.expanduser().resolve()
        if resolved in seen:
            continue
        seen.add(resolved)
        source = source_in_checkout(resolved, args.skill)
        if source is not None:
            break

    managed = args.skill in installed_names or source is not None
    if managed and source is None:
        qualifier = "configured" if authoritative else "recorded or discoverable"
        raise LedgerError(
            f"{args.skill} is project-managed but no valid {qualifier} source checkout "
            f"was found; do not edit deployed copy {deployed}"
        )
    if not managed and not (deployed / "SKILL.md").is_file():
        raise LedgerError(f"skill is not installed: {deployed}")

    result = {
        "skill": args.skill,
        "ownership": "project-managed" if managed else "local-or-third-party",
        "source_path": str(source) if source is not None else None,
        "deployed_path": str(deployed),
        "source_verified": source is not None,
    }
    if source is not None:
        result["checkout"] = str(source.parents[3])
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2, sort_keys=True))
    else:
        print(result["source_path"] or "source unresolved")
        print(f"ownership: {result['ownership']}")
        print(f"source_verified: {str(result['source_verified']).lower()}")
    return 0


def validate_text_field(
    event: dict[str, Any], field: str, line_number: int
) -> str:
    value = event.get(field)
    if not isinstance(value, str) or not value.strip():
        raise LedgerError(
            f"invalid {event.get('event', 'event')} on ledger line {line_number}: "
            f"{field} must be a non-empty string"
        )
    return value


def validate_event(event: Any, line_number: int) -> dict[str, Any]:
    if not isinstance(event, dict):
        raise LedgerError(f"ledger line {line_number} must be a JSON object")
    if type(event.get("schema_version")) is not int:
        raise LedgerError(f"invalid schema type on ledger line {line_number}")
    if event["schema_version"] != SCHEMA_VERSION:
        raise LedgerError(f"unsupported schema on ledger line {line_number}")
    event_name = event.get("event")
    if event_name not in ("observation_created", "observation_resolved"):
        raise LedgerError(f"unknown event on ledger line {line_number}")

    observation_id = validate_text_field(event, "id", line_number)
    try:
        uuid.UUID(observation_id)
    except ValueError as exc:
        raise LedgerError(
            f"invalid {event_name} on ledger line {line_number}: id must be a UUID"
        ) from exc

    recorded_at = validate_text_field(event, "recorded_at", line_number)
    try:
        parsed_at = datetime.fromisoformat(recorded_at)
    except ValueError as exc:
        raise LedgerError(
            f"invalid {event_name} on ledger line {line_number}: "
            "recorded_at must be ISO 8601"
        ) from exc
    if parsed_at.tzinfo is None:
        raise LedgerError(
            f"invalid {event_name} on ledger line {line_number}: "
            "recorded_at must include a timezone"
        )

    if event_name == "observation_created":
        for field in CREATED_TEXT_FIELDS:
            validate_text_field(event, field, line_number)
        if event.get("type") not in VALID_TYPES:
            raise LedgerError(
                f"invalid {event_name} on ledger line {line_number}: "
                f"type must be one of {', '.join(VALID_TYPES)}"
            )
        for field in ("session_context", "reference_file"):
            if field in event:
                validate_text_field(event, field, line_number)
    else:
        if event.get("resolution") not in VALID_RESOLUTIONS:
            raise LedgerError(
                f"invalid {event_name} on ledger line {line_number}: "
                f"resolution must be one of {', '.join(VALID_RESOLUTIONS)}"
            )
        validate_text_field(event, "note", line_number)
    return event


def read_events(handle: TextIO) -> list[dict[str, Any]]:
    handle.seek(0)
    events = []
    for line_number, raw in enumerate(handle, 1):
        if not raw.strip():
            continue
        try:
            event = json.loads(raw)
        except json.JSONDecodeError as exc:
            raise LedgerError(f"invalid JSON on ledger line {line_number}: {exc}") from exc
        events.append(validate_event(event, line_number))
    return events


def build_state(events: list[dict[str, Any]]) -> dict[str, dict[str, Any]]:
    observations: dict[str, dict[str, Any]] = {}
    for event in events:
        observation_id = event.get("id")
        if not isinstance(observation_id, str) or not observation_id:
            raise LedgerError("event has no observation id")
        if event["event"] == "observation_created":
            if observation_id in observations:
                raise LedgerError(f"duplicate observation id: {observation_id}")
            observation = dict(event)
            observation["status"] = "open"
            observations[observation_id] = observation
            continue
        if observation_id not in observations:
            raise LedgerError(f"resolution precedes observation: {observation_id}")
        if observations[observation_id]["status"] != "open":
            raise LedgerError(f"duplicate resolution: {observation_id}")
        observations[observation_id]["status"] = event["resolution"]
        observations[observation_id]["resolved_at"] = event["recorded_at"]
        observations[observation_id]["resolution_note"] = event["note"]
    return observations


def append_event(handle: TextIO, event: dict[str, Any]) -> None:
    handle.seek(0, os.SEEK_END)
    handle.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + "\n")
    handle.flush()
    os.fsync(handle.fileno())


def require_text(value: str, field: str) -> str:
    cleaned = value.strip()
    if not cleaned:
        raise LedgerError(f"{field} must not be empty")
    return cleaned


def command_add(args: argparse.Namespace) -> int:
    path = ledger_path()
    event = {
        "schema_version": SCHEMA_VERSION,
        "event": "observation_created",
        "id": str(uuid.uuid4()),
        "recorded_at": now(),
        "skill": require_text(args.skill, "skill"),
        "type": args.type,
        "area": require_text(args.area, "area"),
        "issue": require_text(args.issue, "issue"),
        "suggested_improvement": require_text(args.improvement, "improvement"),
        "principle": require_text(args.principle, "principle"),
    }
    if args.session_context:
        event["session_context"] = require_text(args.session_context, "session-context")
    if args.reference_file:
        event["reference_file"] = require_text(args.reference_file, "reference-file")
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        build_state(read_events(handle))
        append_event(handle, event)
    print(event["id"])
    return 0


def selected_observations(
    observations: dict[str, dict[str, Any]], status: str
) -> list[dict[str, Any]]:
    selected = list(observations.values())
    if status == "resolved":
        selected = [item for item in selected if item["status"] != "open"]
    elif status != "all":
        selected = [item for item in selected if item["status"] == status]
    return sorted(selected, key=lambda item: (item["recorded_at"], item["id"]))


def load_observations(path: Path) -> dict[str, dict[str, Any]]:
    if not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_SH)
        return build_state(read_events(handle))


def command_list(args: argparse.Namespace) -> int:
    selected = selected_observations(load_observations(ledger_path()), args.status)
    if args.json:
        print(json.dumps(selected, ensure_ascii=False, indent=2, sort_keys=True))
        return 0
    if not selected:
        print(f"no {args.status} observations")
        return 0
    for item in selected:
        print(f"{item['id']} [{item['status']}] {item['skill']} / {item['area']}")
        print(f"  issue: {item['issue']}")
        print(f"  improvement: {item['suggested_improvement']}")
        print(f"  principle: {item['principle']}")
    return 0


def command_review(_: argparse.Namespace) -> int:
    selected = selected_observations(load_observations(ledger_path()), "open")
    print("# Skill Observation Review")
    print()
    print(f"Open observations: {len(selected)}")
    grouped: dict[str, list[dict[str, Any]]] = {}
    for item in selected:
        grouped.setdefault(item["skill"], []).append(item)
    for skill in sorted(grouped):
        print()
        print(f"## {skill}")
        for item in grouped[skill]:
            print(f"- `{item['id']}` {item['issue']}")
            print(f"  - Suggested improvement: {item['suggested_improvement']}")
            print(f"  - Principle: {item['principle']}")
    return 0


def command_resolve(args: argparse.Namespace) -> int:
    path = ledger_path()
    if not path.exists():
        raise LedgerError("ledger does not exist")
    with path.open("r+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        observations = build_state(read_events(handle))
        if args.id not in observations:
            raise LedgerError(f"unknown observation id: {args.id}")
        if observations[args.id]["status"] != "open":
            raise LedgerError(f"observation is already resolved: {args.id}")
        event = {
            "schema_version": SCHEMA_VERSION,
            "event": "observation_resolved",
            "id": args.id,
            "recorded_at": now(),
            "resolution": args.resolution,
            "note": require_text(args.note, "note"),
        }
        append_event(handle, event)
    print(args.id)
    return 0


def parser() -> argparse.ArgumentParser:
    root = argparse.ArgumentParser(description=__doc__)
    commands = root.add_subparsers(dest="command", required=True)

    add = commands.add_parser("add", help="append one observation")
    add.add_argument("--skill", required=True)
    add.add_argument("--area", required=True)
    add.add_argument("--issue", required=True)
    add.add_argument("--improvement", required=True)
    add.add_argument("--principle", required=True)
    add.add_argument("--type", choices=VALID_TYPES, default="internal")
    add.add_argument("--session-context")
    add.add_argument("--reference-file")
    add.set_defaults(run=command_add)

    listing = commands.add_parser("list", help="list current observation state")
    listing.add_argument(
        "--status", choices=("open", "resolved", "actioned", "declined", "all"),
        default="open",
    )
    listing.add_argument("--json", action="store_true")
    listing.set_defaults(run=command_list)

    review = commands.add_parser("review", help="render a read-only Markdown review")
    review.set_defaults(run=command_review)

    target = commands.add_parser(
        "target", help="resolve the authoritative source of a target skill"
    )
    target.add_argument("--skill", required=True)
    target.add_argument("--checkout", help="explicit agent-harness checkout")
    target.add_argument("--skill-root", help="installed shared skill root")
    target.add_argument("--json", action="store_true")
    target.set_defaults(run=command_target)

    resolve = commands.add_parser("resolve", help="append a resolution event")
    resolve.add_argument("--id", required=True)
    resolve.add_argument("--resolution", choices=VALID_RESOLUTIONS, required=True)
    resolve.add_argument("--note", required=True)
    resolve.set_defaults(run=command_resolve)
    return root


def main() -> int:
    try:
        args = parser().parse_args()
        return args.run(args)
    except (LedgerError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())

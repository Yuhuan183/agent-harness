#!/usr/bin/env python3
"""Inspect and validate Codex model-routing recommendations."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / ".agents" / "scripts"))
try:
    import routing_core as core
except ImportError:  # partial deployment: .agents layer not synced
    sys.stderr.write(
        "ERROR: shared routing core missing (<root>/.agents/scripts/routing_core.py); "
        "sync the .agents layer before resolving routes\n")
    sys.exit(2)


CONFIG_PATH = Path(__file__).resolve().parents[1] / "model-routing.toml"
REQUIRED_ROLES = {
    "main",
    "explore",
    "mech-executor",
    "executor",
    "plan-verifier",
    "verifier",
    "security-reviewer",
    "security-executor",
}
REQUIRED_EFFORTS = {"low", "medium", "high", "xhigh", "max"}
REQUIRED_METRICS = {
    "score",
    "cost_usd_per_index_task",
    "decode_minutes_per_index_task",
    "reasoning_tokens_per_index_task",
    "answer_tokens_per_index_task",
    "output_tokens_per_index_task",
}
PROFILE_OBJECTIVES = {
    "fast": "decode_minutes_per_index_task",
    "economy": "cost_usd_per_index_task",
}
AVAILABILITY_SCHEMA = {
    "subscription": {"documented", "unverified"},
    "main_selector": {"documented", "unverified"},
    "native_leaf_override": {"spawn_argument", "agent_config", "unverified"},
    "claude_bridge_override": {"configured", "unverified"},
}
SURFACE_KEYS = {
    "native-leaf": ("native_leaf_override", {"spawn_argument", "agent_config"}),
    "claude-bridge": ("claude_bridge_override", {"configured"}),
}
SURFACE_OVERRIDE_KEYS = {"native-leaf": "native_leaf", "claude-bridge": "claude_bridge"}


def is_dispatchable(model: dict, surface: str = "native-leaf") -> bool:
    key, expected = SURFACE_KEYS[surface]
    return model.get("availability", {}).get(key) in expected


def route_for_surface(
    config: dict, profile_name: str, role: str, surface: str
) -> dict | None:
    override = (
        config.get("surface_overrides", {})
        .get(SURFACE_OVERRIDE_KEYS[surface], {})
        .get(profile_name, {})
        .get("roles", {})
        .get(role)
    )
    if override is not None:
        return override
    return config.get("profiles", {}).get(profile_name, {}).get("roles", {}).get(role)


def validation_errors(config: dict) -> list[str]:
    errors: list[str] = []
    if config.get("version") != 3:
        errors.append("version must be 3")

    models = config.get("models", {})
    profiles = config.get("profiles", {})
    route_application = config.get("route_application", {}).get("roles", {})
    quality_floor = config.get("quality_floor", {})
    role_tiers = quality_floor.get("roles", {})
    allowed_by_tier = quality_floor.get("allowed", {})
    errors += core.check_selection(config)
    errors += core.check_quality_floor_roles(config, REQUIRED_ROLES)
    if set(route_application) != REQUIRED_ROLES:
        errors.append("route_application.roles must cover main and every leaf role")
    for role, application in route_application.items():
        expected = "session_start_recommendation" if role == "main" else "dispatch_override"
        if application != expected:
            errors.append(f"route_application role {role} must be {expected}")

    def route_ok(model_name: str, effort: str) -> str | None:
        model = models.get(model_name)
        if model is None:
            return f"references unknown model: {model_name}"
        if not is_dispatchable(model):
            return f"uses non-dispatchable model: {model_name}"
        if effort not in model.get("efforts", {}):
            return f"references unknown effort: {effort!r}"
        return None

    errors += core.check_allowed_routes(config, route_ok)
    errors += core.check_availability(models, AVAILABILITY_SCHEMA)
    for model_name, model in models.items():
        efforts = model.get("efforts", {})
        if set(efforts) != REQUIRED_EFFORTS:
            errors.append(f"model {model_name} must define low through max efforts")
        for effort, metrics in efforts.items():
            missing_metrics = REQUIRED_METRICS - metrics.keys()
            if missing_metrics:
                errors.append(
                    f"model {model_name}/{effort} missing metrics: "
                    f"{', '.join(sorted(missing_metrics))}"
                )
                continue
            if any(not isinstance(metrics[key], (int, float)) or metrics[key] <= 0
                   for key in REQUIRED_METRICS):
                errors.append(f"model {model_name}/{effort} metrics must be positive numbers")
            token_sum = (
                metrics["reasoning_tokens_per_index_task"]
                + metrics["answer_tokens_per_index_task"]
            )
            if abs(token_sum - metrics["output_tokens_per_index_task"]) > 0.01:
                errors.append(f"model {model_name}/{effort} output token total is inconsistent")
    for profile_name, profile in profiles.items():
        roles = profile.get("roles", {})
        missing = REQUIRED_ROLES - roles.keys()
        extra = roles.keys() - REQUIRED_ROLES
        if missing:
            errors.append(f"profile {profile_name} missing roles: {', '.join(sorted(missing))}")
        if extra:
            errors.append(f"profile {profile_name} has unknown roles: {', '.join(sorted(extra))}")
        for role, route in roles.items():
            model_name = route.get("model")
            effort = route.get("effort")
            model = models.get(model_name)
            if model is None:
                errors.append(f"profile {profile_name}/{role} references unknown model: {model_name!r}")
                continue
            if not is_dispatchable(model):
                errors.append(f"profile {profile_name}/{role} uses non-dispatchable model: {model_name}")
            native_delivery = model.get("availability", {}).get("native_leaf_override")
            if role != "main" and native_delivery == "agent_config" and not route.get("agent_type"):
                errors.append(
                    f"profile {profile_name}/{role} requires agent_type for agent_config delivery"
                )
            if effort not in model.get("efforts", {}):
                errors.append(f"profile {profile_name}/{role} references unknown effort: {effort!r}")
            floor = core.route_floor_error(config, profile_name, role, model_name, effort)
            if floor:
                errors.append(floor)
            if not route.get("reason"):
                errors.append(f"profile {profile_name}/{role} has no reason")

    overrides = config.get("surface_overrides", {})
    extra_surfaces = set(overrides) - set(SURFACE_OVERRIDE_KEYS.values())
    if extra_surfaces:
        errors.append(f"surface_overrides has unknown surfaces: {', '.join(sorted(extra_surfaces))}")
    for surface_name, surface_profiles in overrides.items():
        if surface_name not in SURFACE_OVERRIDE_KEYS.values():
            continue
        for profile_name, profile_override in surface_profiles.items():
            if profile_name not in profiles:
                errors.append(
                    f"surface_overrides.{surface_name} references unknown profile: "
                    f"{profile_name}"
                )
            roles = profile_override.get("roles", {})
            extra_roles = roles.keys() - REQUIRED_ROLES
            if extra_roles:
                errors.append(
                    f"surface_overrides.{surface_name}.{profile_name} has unknown roles: "
                    f"{', '.join(sorted(extra_roles))}"
                )
    for surface in SURFACE_KEYS:
        for profile_name in profiles:
            for role in REQUIRED_ROLES:
                route = route_for_surface(config, profile_name, role, surface)
                if route is None:
                    continue
                model_name = route.get("model")
                effort = route.get("effort")
                model = models.get(model_name)
                if model is None:
                    continue
                if not is_dispatchable(model, surface):
                    errors.append(
                        f"profile {profile_name}/{role} uses model unavailable to "
                        f"{surface}: {model_name}"
                    )
                floor = core.route_floor_error(
                    config, profile_name, role, model_name, effort, context=surface)
                if floor:
                    errors.append(floor)
                if effort not in model.get("efforts", {}):
                    errors.append(
                        f"profile {profile_name}/{role} {surface} references unknown "
                        f"effort: {effort!r}"
                    )
                if not route.get("reason"):
                    errors.append(f"profile {profile_name}/{role} {surface} has no reason")

    for profile_name, metric in PROFILE_OBJECTIVES.items():
        for surface in SURFACE_KEYS:
            for role in profiles.get(profile_name, {}).get("roles", {}):
                chosen = route_for_surface(config, profile_name, role, surface)
                tier = role_tiers.get(role)
                candidates = []
                for route_key in allowed_by_tier.get(tier, []):
                    candidate_model, candidate_effort = route_key.rsplit("/", 1)
                    model = models.get(candidate_model, {})
                    metrics = model.get("efforts", {}).get(candidate_effort)
                    if is_dispatchable(model, surface) and metrics:
                        candidates.append((metrics[metric], route_key))
                chosen_key = f"{chosen.get('model')}/{chosen.get('effort')}"
                if candidates:
                    best_value, best_key = min(candidates)
                    chosen_model = models.get(chosen.get("model"), {})
                    chosen_metrics = chosen_model.get("efforts", {}).get(
                        chosen.get("effort"), {}
                    )
                    chosen_value = chosen_metrics.get(metric)
                    if chosen_value is not None and chosen_value > best_value + 1e-9:
                        errors.append(
                            f"profile {profile_name}/{role} {surface} route {chosen_key} "
                            f"is not optimal for {metric}; {best_key} is lower"
                        )
    return errors


def command_validate(config: dict) -> int:
    errors = validation_errors(config)
    if errors:
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        return 1
    print(
        f"valid: {len(config['profiles'])} profiles, "
        f"{len(config['models'])} benchmark models"
    )
    return 0


def command_list(config: dict, as_json: bool) -> int:
    rows = [
        {"profile": name, "description": profile["description"]}
        for name, profile in config["profiles"].items()
    ]
    if as_json:
        print(json.dumps(rows, indent=2))
    else:
        for row in rows:
            print(f"{row['profile']}: {row['description']}")
    return 0


def command_resolve(
    config: dict, role: str, profile: str | None, priority: str | None, surface: str
) -> int:
    profile_name = core.resolve_profile(config, profile, priority)
    if profile_name not in config["profiles"]:
        print(f"ERROR: unknown profile: {profile_name}", file=sys.stderr)
        return 2
    route = route_for_surface(config, profile_name, role, surface)
    if route is None:
        print(f"ERROR: unknown role: {role}", file=sys.stderr)
        return 2
    model = config["models"][route["model"]]
    if not is_dispatchable(model, surface):
        print(
            f"ERROR: model {route['model']} is not dispatchable on {surface}",
            file=sys.stderr,
        )
        return 2
    metrics = model["efforts"][route["effort"]]
    if role == "main":
        invocation = {"model_delivery": "session_selector"}
    elif surface == "claude-bridge":
        invocation = {
            "agent_type": "codex:codex-rescue",
            "fork_turns": "none",
            "model_delivery": "bridge_argument",
            "pass_model_override": True,
        }
    else:
        delivery = model["availability"]["native_leaf_override"]
        invocation = {
            "agent_type": route.get("agent_type", role),
            "fork_turns": "none",
            "model_delivery": delivery,
            "pass_model_override": delivery == "spawn_argument",
        }
    print(json.dumps({
        "profile": profile_name,
        "objective": config["profiles"][profile_name]["description"],
        "role": role,
        "surface": surface,
        "application": config["route_application"]["roles"][role],
        "quality_tier": config["quality_floor"]["roles"][role],
        **route,
        "invocation": invocation,
        "benchmark_metrics": metrics,
    }, indent=2))
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", type=Path, default=CONFIG_PATH)
    subparsers = parser.add_subparsers(dest="command", required=True)

    list_parser = subparsers.add_parser("list", help="list routing profiles")
    list_parser.add_argument("--json", action="store_true")

    subparsers.add_parser("validate", help="validate routing references")

    resolve_parser = subparsers.add_parser("resolve", help="resolve one role recommendation")
    resolve_parser.add_argument("--role", required=True)
    resolve_parser.add_argument(
        "--surface",
        choices=tuple(SURFACE_KEYS),
        default="native-leaf",
    )
    source = resolve_parser.add_mutually_exclusive_group()
    source.add_argument("--profile")
    source.add_argument("--priority", choices=core.PRIORITY_CHOICES)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    try:
        config = core.load_config(args.config)
    except (OSError, core.tomllib.TOMLDecodeError) as error:
        print(f"ERROR: cannot load routing config: {error}", file=sys.stderr)
        return 2
    errors = validation_errors(config)
    if args.command != "validate" and errors:
        for error in errors:
            print(f"ERROR: {error}", file=sys.stderr)
        return 1
    if args.command == "validate":
        return command_validate(config)
    if args.command == "list":
        return command_list(config, args.json)
    return command_resolve(config, args.role, args.profile, args.priority, args.surface)


if __name__ == "__main__":
    raise SystemExit(main())
